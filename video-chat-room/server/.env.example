# --- Server ---
# Порт сигнального сервера
PORT=3001
# Origin клиента (Vite dev) для CORS; в проде SPA на том же origin
CLIENT_ORIGIN=http://localhost:5173
# Лимит участников в комнате (mesh → 4, PRD F-05)
MAX_MEMBERS=4
# Кольцевой буфер истории чата на комнату (TDD §9)
CHAT_HISTORY_CAP=200
# Максимальная длина сообщения чата (PRD п. 40)
MESSAGE_MAX_LEN=1000
# STUN для справки (клиент использует VITE_STUN_URLS); список через запятую
STUN_URLS=stun:stun.l.google.com:19302
# TLS для HTTPS (secure context). По умолчанию ищется certs/localhost-*.pem.
# Раскомментируйте для своих путей; без сертификата сервер стартует по HTTP (localhost).
# SSL_KEY_FILE=../certs/localhost-key.pem
# SSL_CERT_FILE=../certs/localhost-cert.pem
