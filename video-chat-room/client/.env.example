# --- Client (Vite, переменные с префиксом VITE_) ---
# STUN-серверы для WebRTC ICE (список через запятую). TURN не используется (PRD).
VITE_STUN_URLS=stun:stun.l.google.com:19302
# В dev клиент общается с сервером через Vite-прокси (/socket.io).
# Переопределяйте, только если сервер запущен на другом адресе:
# VITE_SERVER_URL=http://localhost:3001
