{
  "name": "video-chat-room",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Групповой видеочат до 4 участников (WebRTC mesh + Socket.io). Монорепозиторий: server + client.",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "certs": "bash scripts/generate-cert.sh",
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace client",
    "start": "npm run start --workspace server",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=18.18"
  }
}
